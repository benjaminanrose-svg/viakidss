# ─────────────────────────────────────────────────────────────────────────────
# ViaKids Frontend — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env for local development:
#   cp .env.example .env
#
# For Vercel (production), add these as Environment Variables in the Vercel
# project dashboard (Settings → Environment Variables).
# ─────────────────────────────────────────────────────────────────────────────

# Full base URL of the backend API, including the /api path prefix.
#
# Production (Railway):
VITE_API_URL=https://viakidss-production.up.railway.app/api
#
# Local development (Spring Boot running on port 8081):
# VITE_API_URL=http://localhost:8081/api
#
# If this variable is not set, axiosConfig.js falls back to
# http://localhost:8081/api so local development works without a .env file.

# WebSocket URL for real-time bus tracking.
#
# Production (Railway):
# VITE_WS_URL=wss://viakidss-production.up.railway.app/ws
#
# Local development:
# VITE_WS_URL=ws://localhost:8081/ws
